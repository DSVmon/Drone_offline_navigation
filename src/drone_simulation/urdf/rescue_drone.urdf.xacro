<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rescue_drone">

  <!-- Materials -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <!-- Base Link (Body) -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- Gazebo ROS State Plugin -->
  <gazebo>
    <plugin name="gazebo_ros_state" filename="libgazebo_ros_state.so"/>
  </gazebo>

  <!-- Simple Movement Plugin -->
  <gazebo>
    <plugin name="drone_move_controller" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=/cmd_vel</remapping>
      </ros>
      <update_rate>50</update_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- Sensors -->
  <!-- Camera -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.15 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- dToF (Range) -->
  <link name="dtof_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="dtof_joint" type="fixed">
    <parent link="base_link"/>
    <child link="dtof_link"/>
    <origin xyz="0.15 0 -0.02" rpy="0 0 0"/>
  </joint>

  <!-- dToF Back (Range) -->
  <link name="dtof_back_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="dtof_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="dtof_back_link"/>
    <origin xyz="-0.15 0 -0.02" rpy="0 0 3.14159"/>
  </joint>

  <!-- Gazebo Plugins for Sensors -->
  <gazebo reference="camera_link">
    <sensor type="camera" name="rgb_camera">
      <update_rate>30.0</update_rate>
      <camera name="head">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=/camera/image_raw</remapping>
          <remapping>camera_info:=/camera/camera_info</remapping>
        </ros>
        <frame_name>camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=/imu/data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="dtof_link">
    <sensor type="ray" name="dtof_sensor">
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="dtof_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/sensor/dtof_range</remapping>
        </ros>
        <output_type>sensor_msgs/Range</output_type>
        <frame_name>dtof_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="dtof_back_link">
    <sensor type="ray" name="dtof_back_sensor">
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="dtof_back_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/sensor/dtof_back_range</remapping>
        </ros>
        <output_type>sensor_msgs/Range</output_type>
        <frame_name>dtof_back_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <gravity>0</gravity>
  </gazebo>

</robot>
