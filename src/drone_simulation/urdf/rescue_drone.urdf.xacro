<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rescue_drone">

  <!-- Materials -->
  <material name="black">
    <color rgba="0.0 0.0 0.0 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <!-- Base Link (Body) -->
  <link name="base_link">
    <inertial>
      <mass value="0.8"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.2 0.2 0.07"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision name="base_link_collision">
      <geometry>
        <box size="0.2 0.2 0.07"/>
      </geometry>
    </collision>
  </link>

  <!-- Gazebo Material for Base Link and Bumper -->
  <gazebo reference="base_link">
    <visual>
      <material>
        <ambient>1.0 0.5 0.0 1.0</ambient>
        <diffuse>1.0 0.5 0.0 1.0</diffuse>
        <specular>0.1 0.1 0.1 1.0</specular>
        <emissive>0.0 0.0 0.0 0.0</emissive>
      </material>
    </visual>
    <sensor name="drone_bumper" type="contact">
      <always_on>true</always_on>
      <update_rate>50.0</update_rate>
      <contact>
        <collision>base_link_collision</collision>
      </contact>
      <plugin name="drone_bumper_plugin" filename="libgazebo_ros_bumper.so">
        <ros>
          <remapping>bumper_states:=/drone/collisions</remapping>
        </ros>
        <frame_name>base_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Dummy root link to fix KDL warning and improve stability -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Movement Plugin -->
  <gazebo>
    <plugin name="drone_move_controller" filename="libgazebo_ros_planar_move.so">
      <ros>
        <remapping>cmd_vel:=/cmd_vel</remapping>
        <remapping>odom:=/odom</remapping>
      </ros>
      <update_rate>50</update_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- Sensors -->
  <!-- Stereo Camera Base -->
  <link name="camera_link"/>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.1 0 0.035" rpy="0 0 0"/>
  </joint>

  <!-- Left Camera -->
  <link name="camera_left_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="camera_left_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_left_link"/>
    <origin xyz="0 0.03 0" rpy="0 0 0"/>
  </joint>

  <!-- Right Camera -->
  <link name="camera_right_link">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="camera_right_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_right_link"/>
    <origin xyz="0 -0.03 0" rpy="0 0 0"/>
  </joint>

  <!-- IMU -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- dToF (Range) -->
  <link name="dtof_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="dtof_joint" type="fixed">
    <parent link="base_link"/>
    <child link="dtof_link"/>
    <origin xyz="0.1 0 -0.01" rpy="0 0 0"/>
  </joint>

  <!-- dToF Back (Range) -->
  <link name="dtof_back_link">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.01"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="dtof_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="dtof_back_link"/>
    <origin xyz="-0.1 0 -0.01" rpy="0 0 3.14159"/>
  </joint>

  <!-- Gazebo Plugins for Sensors -->
  <!-- Left Camera -->
  <gazebo reference="camera_left_link">
    <sensor type="camera" name="left_camera">
      <update_rate>30.0</update_rate>
      <camera name="left">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin name="left_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=/left/image_raw</remapping>
          <remapping>camera_info:=/left/camera_info</remapping>
        </ros>
        <camera_name>left</camera_name>
        <frame_name>camera_left_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Right Camera -->
  <gazebo reference="camera_right_link">
    <sensor type="camera" name="right_camera">
      <update_rate>30.0</update_rate>
      <camera name="right">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <plugin name="right_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>image_raw:=/right/image_raw</remapping>
          <remapping>camera_info:=/right/camera_info</remapping>
        </ros>
        <camera_name>right</camera_name>
        <frame_name>camera_right_link</frame_name>
        <hack_baseline>0.06</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=/imu/data</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="dtof_link">
    <sensor type="ray" name="dtof_sensor">
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="dtof_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/sensor/dtof_range</remapping>
        </ros>
        <output_type>sensor_msgs/Range</output_type>
        <frame_name>dtof_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="dtof_back_link">
    <sensor type="ray" name="dtof_back_sensor">
      <visualize>true</visualize>
      <update_rate>20</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="dtof_back_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/sensor/dtof_back_range</remapping>
        </ros>
        <output_type>sensor_msgs/Range</output_type>
        <frame_name>dtof_back_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
    <gravity>0</gravity>
  </gazebo>

</robot>
